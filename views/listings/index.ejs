<% layout("layouts/boilerplate.ejs") %>

    <body>

        <style>
            #filters {
                display: flex;
                align-items: center;
                flex-wrap: wrap;
                margin: 0 0 1rem 0;
            }

            .filter {
                text-align: center;
                margin-right: 1.2rem;
                margin-top: 1.5rem;
                opacity: 0.7;
            }

            .filter:hover {
                opacity: 1;
                cursor: pointer;
            }

            .filter p {
                font-size: 0.8rem;
                color: #38386b;
            }

            @media (max-width: 576px) {
                #filters {
                    gap: 1rem;
                }

                .filter {
                    margin: 0.5rem;
                }

                .filter p {
                    font-size: 0.7rem;
                }
            }

            .tax-info {
                display: none;
            }

            .tax-toggle {
                border: 1px solid #cfcfcf;
                border-radius: 1rem;
                padding: 0.8rem 1rem;
                margin-left: 2rem;
                display: flex;
                align-items: center;
            }

            .form-check-input:checked {
                background-color: #fe424d !important;
                border-color: #fe424d !important;
            }
            .tax-toggle:hover{
                background-color: #eeeefa;
            }
        </style>

        <div id="filters">
            <div class="filter">
                <div><i class="fa-solid fa-fire"></i></div>
                <p>Trending</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-bed"></i></div>
                <p>Rooms</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-mountain-city"></i></div>
                <p>Iconic Cities</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-mountain"></i></div>
                <p>Mountains</p>
            </div>
            <div class="filter">
                <div><i class="fa-brands fa-fort-awesome"></i></div>
                <p>Castles</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-person-swimming"></i></div>
                <p>Amazing Pools</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-campground"></i></div>
                <p>Camping</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-cow"></i></div>
                <p>Farms</p>
            </div>
            <div class="filter">
                <div><i class="fa-regular fa-snowflake"></i></div>
                <p>Arctic</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-igloo"></i></div>
                <p>Domes</p>
            </div>
            <div class="filter">
                <div><i class="fa-solid fa-ship"></i></div>
                <p>Boats</p>
            </div>


            <div class="tax-toggle">
                <div class="form-check-reverse form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                    <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
                </div>
            </div>
        </div>

        <% if(allListings.length === 0){ %>
    <div class="alert alert-warning text-center mt-4">
        No listings found.
    </div>
<% } %>


        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <%for(let listings of allListings){ %>
                <a href="/listings/<%=listings._id%>" class="listing-link">
                    <div class="card col listing-card">
                        <img src="<%= listings.image.url %>" class="card-img-top" alt="listing_image">
                        <div class="card-img-overlay"></div>
                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%= listings.title %>
                                </b>
                                <br>
                                <%= listings.price.toLocaleString("en-In") %> / night
                                    <i class="tax-info"> &nbsp; &nbsp; +18% GST</i>
                            </p>
                        </div>
                    </div>
                </a>
                <%}%>
        </div>
    </body>

    <script>
        let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("change", () => {
            let taxInfo = document.getElementsByClassName("tax-info");

            for (let info of taxInfo) {
                info.style.display = taxSwitch.checked ? "inline" : "none";
            }
        })
    </script>